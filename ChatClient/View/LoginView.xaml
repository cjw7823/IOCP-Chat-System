<UserControl x:Class="ChatClient.View.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="640"
             d:DesignWidth="380">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BorderBrushGray" Color="#D9D9D9"/>
        <SolidColorBrush x:Key="TextBrushGray" Color="#5F5F5F"/>

        <Style x:Key="InputContainerStyle" TargetType="Border">
            <Setter Property="Height" Value="54"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
        </Style>
        
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#A8A8A8"/>
            <Setter Property="Background" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#EAEAEA"/>
                                <Setter Property="Foreground" Value="#A8A8A8"/>
                                <Setter Property="BorderBrush" Value="#D9D9D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#A0DE10">
        <StackPanel Margin="50, 100" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- 로고 -->
            <Grid HorizontalAlignment="Center" Margin="0,0,0,34"
                  Width="100" Height="78">
                <Ellipse Width="150"
                             Height="78"
                             Margin="-25,0,-25,0"
                             Fill="#3A2A28"/>

                <TextBlock Text="Chat"
                               Foreground="#A0DE10"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-2,0,0"/>
            </Grid>

            <!-- 아이디 입력 -->
            <Border Style="{StaticResource InputContainerStyle}">
                <Grid>
                    <TextBox x:Name="idBox"
                             Text="{Binding UserId}"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             TextChanged="TextBox_TextChanged"/>

                    <TextBlock x:Name="watermarkText1" IsHitTestVisible ="False"
                               VerticalAlignment="Center"
                               Text=" ID" Foreground="Gray"
                               FontSize="14" FontWeight="Bold"/>
                </Grid>
            </Border>
            
            <!-- 비밀번호 -->
            <Border Style="{StaticResource InputContainerStyle}" Margin="0,-1,0,0">
                <Grid>
                    <PasswordBox x:Name="pwBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="pwBox_PasswordChanged"/>

                    <TextBlock x:Name="watermarkText2" IsHitTestVisible ="False"
                               VerticalAlignment="Center"
                               Text=" PW" Foreground="Gray"
                               FontSize="14" FontWeight="Bold"/>
                </Grid>
            </Border>

            <!-- 로그인 버튼 -->
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,8,0,0"
                    Content="로그인"
                    Foreground="White"
                    Background="#3A2A28"
                    BorderBrush="#3A2A28"
                    Command="{Binding ClickLoginCommand}"/>

            <!-- 회원가입 버튼 -->
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,8,0,0"
                    Content="회원가입"
                    Foreground="#3A2A28"
                    Background="White"
                    BorderBrush="#3A2A28"
                    Command="{Binding ClickRegisterCommand}"/>

            <!-- 자동 로그인 -->
            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                <CheckBox VerticalAlignment="Center"
                          IsChecked="True"/>

                <TextBlock Text="자동 로그인"
                           Margin="6,0,4,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource TextBrushGray}"/>

                <Border Width="16"
                        Height="16"
                        CornerRadius="8"
                        BorderBrush="{StaticResource TextBrushGray}"
                        BorderThickness="1"
                        Background="Transparent"
                        VerticalAlignment="Center">
                    <TextBlock Text="i"
                               FontSize="10"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextBrushGray}"/>
                </Border>
            </StackPanel>
            <TextBox TextWrapping="Wrap" Text="{Binding StatusMessage}"
                     Foreground="IndianRed"
                     Background="Transparent"
                     BorderBrush="Transparent"
                     FontSize="15"
                     VerticalAlignment="Center"
                     TextAlignment="Center"
                     Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>