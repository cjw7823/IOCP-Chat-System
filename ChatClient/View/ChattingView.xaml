<UserControl x:Class="ChatClient.View.ChattingView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:service="clr-namespace:ChatClient.Service"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ChatClient.View"
      xmlns:viewModel="clr-namespace:ChatClient.ViewModel"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=viewModel:MainViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <!-- 상대방 메시지 템플릿 -->
        <DataTemplate x:Key="IncomingMessageTemplate">
            <StackPanel HorizontalAlignment="Left" Margin="0,6">
                <TextBlock Text="{Binding SenderName}"
                       FontSize="12"
                       Foreground="Black"
                       Margin="40,0,0,2"/>

                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="34"
                         Height="34"
                         Fill="White"
                         Stroke="Gray"
                         VerticalAlignment="Top"
                         Margin="0,0,6,0"/>

                    <Border Background="White"
                        CornerRadius="6"
                        Padding="10,6"
                        MaxWidth="220">
                        <TextBlock Text="{Binding Text}"
                               TextWrapping="Wrap"
                               FontSize="14"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- 내 메시지 템플릿 -->
        <DataTemplate x:Key="OutgoingMessageTemplate">
            <StackPanel HorizontalAlignment="Right" Margin="0,6">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding TimeText}"
                           VerticalAlignment="Bottom"
                           Margin="0,0,6,0"
                           FontSize="11"
                           Foreground="DimGray"/>

                    <Border Background="#FEE500"
                        CornerRadius="6"
                        Padding="10,6"
                        MaxWidth="220">
                        <TextBlock Text="{Binding Text}"
                               TextWrapping="Wrap"
                               FontSize="14"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- 템플릿 선택기 -->
        <service:ChatMessageTemplateSelector x:Key="ChatTemplateSelector"
                                           IncomingTemplate="{StaticResource IncomingMessageTemplate}"
                                           OutgoingTemplate="{StaticResource OutgoingMessageTemplate}" />
    </UserControl.Resources>

    <Grid Background="#B9C9D9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="34*"/>
            <ColumnDefinition Width="121*"/>
            <ColumnDefinition Width="35*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="140"/>
        </Grid.RowDefinitions>

        <!-- 상단 헤더 -->
        <Grid Grid.Row="0" Background="#B9C9D9" Margin="10,0,10,0" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Ellipse Width="40" Height="40"
                 Fill="White"
                 Stroke="Gray"
                 VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                    Orientation="Vertical"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
                <TextBlock Text="단체방"
                       FontSize="18"
                       FontWeight="SemiBold"/>
                <TextBlock Text="n명"
                       FontSize="12"
                       Foreground="DimGray"/>
            </StackPanel>

            <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                <Button Content="🔍" Width="32" Height="32" Margin="2"/>
                <Button Content="📞" Width="32" Height="32" Margin="2"/>
                <Button Content="☰" Width="32" Height="32" Margin="2"/>
            </StackPanel>
        </Grid>

        <!-- 채팅 영역 -->
        <ListBox Grid.Row="1"
             Grid.ColumnSpan="3"
             ItemsSource="{Binding Messages}"
             ItemTemplateSelector="{StaticResource ChatTemplateSelector}"
             Background="#B9C9D9"
             BorderThickness="0"
             Padding="10"
             HorizontalContentAlignment="Stretch"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.CanContentScroll="False">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Focusable" Value="False"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- 입력 영역 -->
        <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="1,1,0,0" Grid.ColumnSpan="3" Margin="0,414,0,0" Grid.RowSpan="2">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="InputBox"
                     Grid.Row="0"
                     BorderThickness="0"
                     Background="#F5F5F5"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="14"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" TextChanged="InputBox_TextChanged"
                     />

                <TextBlock x:Name="watermarkText" IsHitTestVisible ="False">
                <Run Language="ko-kr" Text=" 메시지 입력" Foreground="Gray"
                     FontSize="14" FontWeight="Bold"/>
                </TextBlock>

                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="＋" Width="30" Height="30" Margin="0,0,6,0"/>
                    <Button Grid.Column="1" Content="☺" Width="30" Height="30"/>

                    <Button Grid.Column="3"
                        Content="전송"
                        Height="32"
                        Margin="8,0,0,0"
                        Command="{Binding SendCommand}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
